# BLKOUT Website Environment Variables
# Copy this file to .env.local for development
# Configure these in Vercel Environment Variables for production

# N8N Automation Webhooks
VITE_N8N_WEBHOOK_URL=https://n8n.blkoutuk.com/webhook/community-signup
VITE_BACKUP_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/backup/

# OpenAI API for IVOR Chatbot
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Analytics and Tracking (Optional)
VITE_ANALYTICS_ID=your_analytics_id_here

# Community Features
VITE_BLKOUTHUB_API_URL=https://api.blkoutuk.com/hub
VITE_COMMUNITY_API_KEY=your_community_api_key_here

# Email Service Configuration
VITE_EMAIL_SERVICE_URL=https://api.blkoutuk.com/email
VITE_MAILCHIMP_API_KEY=your_mailchimp_api_key_here

# Development vs Production
VITE_ENVIRONMENT=development